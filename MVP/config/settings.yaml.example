# 新闻爬虫与 AI 整理系统配置文件
# 复制此文件为 settings.yaml 并填写实际配置

# 定时任务配置
scheduler:
  # 定时执行时间点，格式: "HH:MM"
  cron_times:
    - "08:30"
    - "11:30"
    - "17:30"
  # 时区
  timezone: "Asia/Shanghai"

# 爬虫配置
crawlers:
  # 启用的爬虫列表
  enabled:
    - jqzx
    - kr36
    - aiera
    - radar
    - qbit
  # 请求超时（秒）
  timeout: 30
  # 请求间隔（秒）
  request_delay: 2

# 数据库配置
database:
  # SQLite 数据库文件路径
  path: "./data/news.db"

# 大模型配置
llm:
  # API 基础地址（兼容 OpenAI 协议）
  base_url: "https://api.openai.com/v1"
  # API Key
  api_key: "your-api-key-here"
  # 模型名称
  model: "gpt-4"
  # 最大重试次数
  max_retries: 3
  # 超时时间（秒）
  timeout: 60

# 飞书通知配置
feishu:
  # Webhook 地址
  webhook_url: "https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-key"
  # 是否启用
  enabled: true

# 163 邮件配置
email_163:
  # 发件人邮箱
  sender: "your-email@163.com"
  # 授权码/密码
  password: "your-authorization-code"
  # 收件人列表
  recipients:
    - "recipient1@example.com"
    - "recipient2@example.com"
  # 是否启用
  enabled: true

# 日志配置
logging:
  # 日志级别: DEBUG, INFO, WARNING, ERROR
  level: "INFO"
  # 日志文件路径
  file_path: "./logs/news_agent.log"
  # 日志文件最大大小（MB）
  rotation: "50 MB"
  # 保留天数
  retention: "30 days"
